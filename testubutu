#!/usr/bin/env bash
set -e

#####################################
# CONFIG
#####################################

IMG_URL="https://dumgzwin.atl1.cdn.digitaloceanspaces.com/winDO2222.gz"
WORKDIR="/tmp/wininstall"
DISK=""

#####################################
# LOG
#####################################

log() {
    echo "[+] $1"
}

#####################################
# DETECT DISK
#####################################

detect_disk() {

DISK=$(lsblk -dpno NAME,TYPE | awk '$2=="disk"{print $1}' | head -n1)

if [ -z "$DISK" ]; then
    echo "No disk detected!"
    exit 1
fi

log "Target disk: $DISK"

}

#####################################
# CIDR -> NETMASK
#####################################

cidr_to_mask() {

local cidr=$1
local mask=""
local full_octets=$((cidr/8))
local partial_octet=$((cidr%8))

for ((i=0;i<4;i++)); do
if [ $i -lt $full_octets ]; then
mask+=255
elif [ $i -eq $full_octets ]; then
mask+=$((256-2**(8-$partial_octet)))
else
mask+=0
fi
[ $i -lt 3 ] && mask+=.
done

echo $mask
}

#####################################
# DETECT NETWORK
#####################################

detect_network() {

log "Detecting network..."

route=$(ip -4 route get 1.1.1.1)

IFACE=$(echo $route | awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}')
GW=$(echo $route | awk '{for(i=1;i<=NF;i++) if($i=="via"){print $(i+1); exit}}')

IPCIDR=$(ip -4 -o addr show dev $IFACE scope global | awk '{print $4}' | head -n1)

IPADDR=${IPCIDR%/*}
CIDR=${IPCIDR#*/}

MASK=$(cidr_to_mask $CIDR)

DNS1=$(grep nameserver /etc/resolv.conf | head -n1 | awk '{print $2}')

if [[ "$DNS1" == "127.0.0.53" ]]; then
DNS1="8.8.8.8"
fi

log "IP: $IPADDR"
log "MASK: $MASK"
log "GW: $GW"
log "DNS: $DNS1"

}

#####################################
# PREPARE STAGE2 SCRIPT
#####################################

prepare_stage2() {

mkdir -p $WORKDIR

cat <<EOF > $WORKDIR/stage2.sh
#!/usr/bin/env bash
set -e

echo "[+] Stage2 running in RAM"

DISK="$DISK"
IMG_URL="$IMG_URL"

mkdir -p /mnt/win

echo "[+] Writing Windows image..."

curl -L \$IMG_URL | gunzip | dd of=\$DISK bs=16M status=progress

sync

echo "[+] Searching Windows partition..."

for part in \${DISK}*; do

if mount \$part /mnt/win 2>/dev/null; then

if [ -d "/mnt/win/Windows" ]; then

echo "[+] Windows partition found"

cat <<CONF > /mnt/win/netconfig.txt
IP=$IPADDR
MASK=$MASK
GW=$GW
DNS1=$DNS1
PASS=Admin123!
CONF

sync
umount /mnt/win
break
fi

umount /mnt/win
fi

done

echo "[+] Installation finished"
echo "[+] Rebooting..."

reboot -f
EOF

chmod +x $WORKDIR/stage2.sh

}

#####################################
# KEXEC INTO RAM
#####################################

boot_ram_stage() {

log "Loading RAM kernel..."

apt-get update -y
apt-get install -y kexec-tools

KERNEL=$(ls /boot/vmlinuz* | head -n1)
INITRD=$(ls /boot/initrd.img* | head -n1)

kexec -l \$KERNEL \
--initrd=\$INITRD \
--command-line="init=/bin/bash"

log "Switching to RAM environment..."

sync
kexec -e

}

#####################################
# MAIN
#####################################

detect_disk
detect_network
prepare_stage2
boot_ram_stage
