#!/usr/bin/env bash
set -euo pipefail

IMG_URL="${IMG_URL:-https://your-server.example.com/windows.gz}"
DISK="${DISK:-/dev/vda}"
MOUNTDIR="/mnt/win"
PASSWORD="${PASSWORD:-Admin@123456}"
MODE="${MODE:-static}"

log() {
    echo "[$(date '+%F %T')] $*"
}

fail() {
    echo "[ERROR] $*" >&2
    exit 1
}

cidr_to_mask() {
    local cidr="$1"
    local mask=""
    local full_octets=$((cidr / 8))
    local partial_octet=$((cidr % 8))
    local i

    for ((i=0; i<4; i++)); do
        if (( i < full_octets )); then
            mask+="255"
        elif (( i == full_octets && partial_octet > 0 )); then
            mask+="$((256 - 2**(8-partial_octet)))"
        else
            mask+="0"
        fi
        [[ $i -lt 3 ]] && mask+="."
    done

    echo "$mask"
}

detect_network() {
    local route iface_cidr

    route="$(ip -4 route get 1.1.1.1 2>/dev/null | head -n1)"
    IFACE="$(awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}' <<<"$route")"
    GW="$(awk '{for(i=1;i<=NF;i++) if($i=="via"){print $(i+1); exit}}' <<<"$route")"

    iface_cidr="$(ip -4 -o addr show dev "$IFACE" scope global | awk '{print $4}' | head -n1)"
    IPADDR="${iface_cidr%/*}"
    CIDR="${iface_cidr#*/}"
    MASK="$(cidr_to_mask "$CIDR")"

    DNS1="$(awk '/^nameserver /{print $2; exit}' /etc/resolv.conf)"
    DNS2="$(awk '/^nameserver /{count++; if(count==2){print $2; exit}}' /etc/resolv.conf)"

    [[ -z "$DNS1" ]] && DNS1="8.8.8.8"
}

prepare_disk() {
    log "Disabling swap"
    swapoff -a || true

    log "Unmounting partitions on $DISK"
    while read -r name; do
        [[ "$name" == "$(basename "$DISK")" ]] && continue
        umount "/dev/$name" 2>/dev/null || true
    done < <(lsblk -ln "$DISK" -o NAME)
}

write_image() {
    log "Downloading and writing image to $DISK"
    curl -L "$IMG_URL" | gunzip | dd of="$DISK" bs=16M status=progress conv=fsync
    sync
    partprobe "$DISK" || true
    sleep 3
}

mount_windows_partition() {
    mkdir -p "$MOUNTDIR"

    for part in "${DISK}"*; do
        [[ "$part" == "$DISK" ]] && continue
        if mount "$part" "$MOUNTDIR" 2>/dev/null; then
            if [[ -d "$MOUNTDIR/Windows" ]]; then
                WINPART="$part"
                log "Mounted Windows partition: $WINPART"
                return 0
            fi
            umount "$MOUNTDIR" || true
        fi
    done

    fail "Windows partition not found"
}

write_netconfig() {
    local cfg="$MOUNTDIR/netconfig.txt"

    if [[ "$MODE" == "dhcp" ]]; then
        cat > "$cfg" <<EOF
MODE=dhcp
PASSWORD=$PASSWORD
EOF
    else
        cat > "$cfg" <<EOF
MODE=static
IP=$IPADDR
MASK=$MASK
GW=$GW
DNS1=$DNS1
DNS2=${DNS2:-}
PASSWORD=$PASSWORD
EOF
    fi

    sync
    log "Written $cfg"
}

main() {
    [[ $EUID -eq 0 ]] || fail "Run as root"
    [[ -b "$DISK" ]] || fail "Disk not found: $DISK"

    if [[ "$MODE" == "static" ]]; then
        detect_network
        log "IP=$IPADDR MASK=$MASK GW=$GW DNS1=$DNS1 DNS2=${DNS2:-}"
    fi

    prepare_disk
    write_image
    mount_windows_partition
    write_netconfig

    umount "$MOUNTDIR" || true
    sync

    log "Done. Rebooting..."
    reboot -f
}

main "$@"
