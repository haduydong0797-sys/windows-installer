#!/usr/bin/env bash
set -e

#######################################
# CONFIG
#######################################

IMG_URL="https://your-server/windows.gz"
DISK="/dev/vda"

MOUNT_DIR="/mnt/win"

#######################################
# CIDR â†’ NETMASK
#######################################

cidr_to_mask() {

local cidr=$1
local mask=""
local full_octets=$((cidr/8))
local partial_octet=$((cidr%8))

for ((i=0;i<4;i++)); do
if [ $i -lt $full_octets ]; then
mask+=255
elif [ $i -eq $full_octets ]; then
mask+=$((256-2**(8-$partial_octet)))
else
mask+=0
fi
[ $i -lt 3 ] && mask+=.
done

echo $mask
}

#######################################
# DETECT NETWORK
#######################################

detect_network() {

echo "Detecting network..."

route=$(ip -4 route get 1.1.1.1)

IFACE=$(echo $route | awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}')
GW=$(echo $route | awk '{for(i=1;i<=NF;i++) if($i=="via"){print $(i+1); exit}}')

IPCIDR=$(ip -4 -o addr show dev $IFACE scope global | awk '{print $4}' | head -n1)

IPADDR=${IPCIDR%/*}
CIDR=${IPCIDR#*/}

MASK=$(cidr_to_mask $CIDR)

DNS1=$(grep nameserver /etc/resolv.conf | head -n1 | awk '{print $2}')
DNS2=$(grep nameserver /etc/resolv.conf | sed -n 2p | awk '{print $2}')

echo "IP: $IPADDR"
echo "MASK: $MASK"
echo "GW: $GW"
echo "DNS1: $DNS1"
echo "DNS2: $DNS2"
}

#######################################
# PREPARE DISK
#######################################

prepare_disk() {

echo "Stopping swap..."
swapoff -a || true

echo "Unmounting partitions..."

lsblk -ln $DISK | awk '{print $1}' | while read part; do
umount "/dev/$part" 2>/dev/null || true
done

}

#######################################
# WRITE WINDOWS IMAGE
#######################################

write_image() {

echo "Downloading and writing image..."

curl -L $IMG_URL | gunzip | dd of=$DISK bs=16M status=progress

sync
partprobe $DISK || true
sleep 3

}

#######################################
# FIND WINDOWS PARTITION
#######################################

mount_windows_partition() {

mkdir -p $MOUNT_DIR

for part in ${DISK}*; do

if mount $part $MOUNT_DIR 2>/dev/null; then

if [ -d "$MOUNT_DIR/Windows" ]; then
WINPART=$part
echo "Windows partition found: $WINPART"
return
fi

umount $MOUNT_DIR

fi

done

echo "Windows partition not found!"
exit 1
}

#######################################
# CREATE NETWORK CONFIG
#######################################

create_netconfig() {

echo "Writing network config..."

cat <<EOF > $MOUNT_DIR/netconfig.txt
IP=$IPADDR
MASK=$MASK
GW=$GW
DNS1=$DNS1
DNS2=$DNS2
PASS=Admin123!
EOF

sync

}

#######################################
# REBOOT
#######################################

finish() {

umount $MOUNT_DIR || true

echo "Installation complete."
echo "Rebooting..."

reboot -f

}

#######################################
# MAIN
#######################################

detect_network
prepare_disk
write_image
mount_windows_partition
create_netconfig
finish
