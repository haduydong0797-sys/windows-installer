#!/usr/bin/env bash
set -e

IMG_URL="https://dumgzwin.atl1.cdn.digitaloceanspaces.com/winDO2222.gz"
MOUNT_DIR="/mnt/win"

log() {
 echo "[+] $1"
}

###################################
# Detect disk
###################################

DISK=$(lsblk -dpno NAME,TYPE | awk '$2=="disk"{print $1}' | head -n1)

if [ -z "$DISK" ]; then
 echo "No disk detected!"
 exit 1
fi

log "Target disk: $DISK"

###################################
# Detect network
###################################

log "Detecting network..."

ROUTE=$(ip -4 route get 1.1.1.1)

IFACE=$(echo $ROUTE | awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}')
GW=$(echo $ROUTE | awk '{for(i=1;i<=NF;i++) if($i=="via"){print $(i+1); exit}}')

IPCIDR=$(ip -4 -o addr show dev $IFACE scope global | awk '{print $4}' | head -n1)

IPADDR=${IPCIDR%/*}
CIDR=${IPCIDR#*/}

cidr_to_mask() {
local cidr=$1
local mask=""
local full_octets=$((cidr/8))
local partial_octet=$((cidr%8))

for ((i=0;i<4;i++)); do
 if [ $i -lt $full_octets ]; then
 mask+=255
 elif [ $i -eq $full_octets ]; then
 mask+=$((256-2**(8-$partial_octet)))
 else
 mask+=0
 fi
 [ $i -lt 3 ] && mask+=.
done

echo $mask
}

MASK=$(cidr_to_mask $CIDR)

DNS1=$(grep nameserver /etc/resolv.conf | head -n1 | awk '{print $2}')
[ "$DNS1" = "127.0.0.53" ] && DNS1="8.8.8.8"

log "IP: $IPADDR"
log "MASK: $MASK"
log "GW: $GW"
log "DNS: $DNS1"

###################################
# Prepare disk
###################################

log "Stopping swap..."

swapoff -a || true

log "Unmounting partitions..."

lsblk -ln $DISK | awk '{print $1}' | while read part; do
 umount "/dev/$part" 2>/dev/null || true
done

###################################
# Write Windows image
###################################

log "Downloading and writing image..."

curl -L $IMG_URL | gunzip | dd of=$DISK bs=16M status=progress

sync

###################################
# Inject network config
###################################

log "Mounting Windows partition..."

mkdir -p $MOUNT_DIR

sleep 3
partprobe $DISK || true

for part in ${DISK}*; do

 if mount $part $MOUNT_DIR 2>/dev/null; then

  if [ -d "$MOUNT_DIR/Windows" ]; then

   log "Windows partition found"

   cat <<EOF > $MOUNT_DIR/netconfig.txt
IP=$IPADDR
MASK=$MASK
GW=$GW
DNS1=$DNS1
PASS=Admin123!
EOF

   sync
   umount $MOUNT_DIR
   break

  fi

  umount $MOUNT_DIR

 fi

done

###################################
# Reboot
###################################

log "Installation finished"
log "Rebooting..."

echo 1 > /proc/sys/kernel/sysrq
echo b > /proc/sysrq-trigger
