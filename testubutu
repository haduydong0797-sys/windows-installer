#!/usr/bin/env bash
set -e

IMG_URL="https://dumgzwin.atl1.cdn.digitaloceanspaces.com/winDO99.gz"
DISK="/dev/vda"

echo "Installing Windows on $DISK"

swapoff -a || true

lsblk -ln $DISK | awk '{print $1}' | while read part; do
    umount "/dev/$part" 2>/dev/null || true
done

curl -L "$IMG_URL" | gunzip | dd of="$DISK" bs=16M status=progress

sync

echo "Installation finished, rebooting..."

reboot -f
