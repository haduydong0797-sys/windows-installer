#!/usr/bin/env bash
set -e

#####################################
# CONFIG
#####################################

IMG_URL="https://dumgzwin.atl1.cdn.digitaloceanspaces.com/winDO2222.gz"
WORKDIR="/tmp/wininst"
MOUNT="/mnt/win"

log() { echo "[+] $1"; }

#####################################
# Detect disk
#####################################

DISK=$(lsblk -dpno NAME,TYPE | awk '$2=="disk"{print $1}' | head -n1)

if [ -z "$DISK" ]; then
 echo "No disk found!"
 exit 1
fi

log "Target disk: $DISK"

#####################################
# Detect network
#####################################

log "Detecting network..."

ROUTE=$(ip -4 route get 1.1.1.1)

IFACE=$(echo $ROUTE | awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}')
GW=$(echo $ROUTE | awk '{for(i=1;i<=NF;i++) if($i=="via"){print $(i+1); exit}}')

IPCIDR=$(ip -4 -o addr show dev $IFACE scope global | awk '{print $4}' | head -n1)

IPADDR=${IPCIDR%/*}
CIDR=${IPCIDR#*/}

cidr_to_mask() {
local cidr=$1
local mask=""
local full_octets=$((cidr/8))
local partial_octet=$((cidr%8))

for ((i=0;i<4;i++)); do
 if [ $i -lt $full_octets ]; then
 mask+=255
 elif [ $i -eq $full_octets ]; then
 mask+=$((256-2**(8-$partial_octet)))
 else
 mask+=0
 fi
 [ $i -lt 3 ] && mask+=.
done

echo $mask
}

MASK=$(cidr_to_mask $CIDR)

DNS1=$(grep nameserver /etc/resolv.conf | head -n1 | awk '{print $2}')
[ "$DNS1" = "127.0.0.53" ] && DNS1="8.8.8.8"

log "IP: $IPADDR"
log "MASK: $MASK"
log "GW: $GW"
log "DNS: $DNS1"

#####################################
# Install kexec
#####################################

log "Installing kexec..."

apt-get update -y
apt-get install -y kexec-tools

#####################################
# Prepare stage2
#####################################

mkdir -p $WORKDIR

cat <<EOF > $WORKDIR/stage2.sh
#!/usr/bin/env bash
set -e

DISK="$DISK"
IMG_URL="$IMG_URL"
MOUNT="$MOUNT"

echo "[+] Stage2 running from RAM"

mkdir -p \$MOUNT

echo "[+] Writing Windows image..."

curl -L \$IMG_URL | gunzip | dd of=\$DISK bs=16M status=progress

sync
sleep 2

echo "[+] Searching Windows partition..."

for part in \${DISK}*; do

 if mount \$part \$MOUNT 2>/dev/null; then

  if [ -d "\$MOUNT/Windows" ]; then

   echo "[+] Windows partition found"

   cat <<CONF > \$MOUNT/netconfig.txt
IP=$IPADDR
MASK=$MASK
GW=$GW
DNS1=$DNS1
PASS=Admin123!
CONF

   sync
   umount \$MOUNT
   break

  fi

  umount \$MOUNT

 fi

done

echo "[+] Installation complete"
echo "[+] Rebooting..."

reboot -f
EOF

chmod +x $WORKDIR/stage2.sh

#####################################
# Find kernel
#####################################

log "Preparing RAM environment..."

mkdir -p /tmp/ramstage

cat <<'EOF' > /tmp/ramstage/init
#!/bin/sh

echo "[+] RAM stage started"

mount -t proc none /proc
mount -t sysfs none /sys

/tmp/stage2.sh
EOF

chmod +x /tmp/ramstage/init

cp $WORKDIR/stage2.sh /tmp/stage2.sh

####################################
# Load kernel into RAM
####################################

KERNEL=$(find /boot -name "vmlinuz*" | head -n1)
INITRD=$(find /boot -name "initrd.img*" | head -n1)

echo "[+] Kernel: $KERNEL"

kexec -l "$KERNEL" \
 --initrd="$INITRD" \
 --command-line="init=/tmp/ramstage/init"

sync

echo "[+] Booting RAM environment..."

kexec -e
